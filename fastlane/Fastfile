# Fastlane config for UltraEdge iOS (Expo app with committed ios/ project).
# Builds the committed ios/ project directly — no expo prebuild involved.

default_platform(:ios)

APP_IDENTIFIER = "com.beaux.ultraedge"
IOS_DIR = File.expand_path("../ios", __dir__)
WORKSPACE = File.join(IOS_DIR, "UltraEdge.xcworkspace")
XCODEPROJ = File.join(IOS_DIR, "UltraEdge.xcodeproj")
SCHEME = "UltraEdge"
OUTPUT_DIR = File.expand_path("../build", __dir__)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build a Release archive without uploading (local verification)"
  lane :build do
    api_key = asc_api_key
    ensure_pods
    configure_signing(api_key: api_key)
    archive
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = asc_api_key
    UI.user_error!(
      "App Store Connect API key not configured. " \
      "Set ASC_KEY_ID, ASC_ISSUER_ID and ASC_KEY_P8 (or ASC_KEY_PATH). " \
      "See fastlane/.env.example."
    ) if api_key.nil?

    ensure_pods
    configure_signing(api_key: api_key)
    bump_build_number(api_key: api_key)
    archive
    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Install CocoaPods dependencies if missing or out of date"
  private_lane :ensure_pods do
    cocoapods(
      podfile: File.join(IOS_DIR, "Podfile"),
      deployment: false,
      try_repo_update_on_error: true
    )
  end

  desc "Returns an ASC API key hash from env vars, or nil if not configured"
  private_lane :asc_api_key do
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]

    if key_id.to_s.empty? || issuer_id.to_s.empty?
      nil
    elsif !ENV["ASC_KEY_P8"].to_s.empty?
      app_store_connect_api_key(
        key_id: key_id,
        issuer_id: issuer_id,
        key_content: ENV["ASC_KEY_P8"],
        is_key_content_base64: ENV["ASC_KEY_P8_BASE64"] == "true"
      )
    elsif !ENV["ASC_KEY_PATH"].to_s.empty?
      app_store_connect_api_key(
        key_id: key_id,
        issuer_id: issuer_id,
        key_filepath: ENV["ASC_KEY_PATH"]
      )
    end
  end

  desc "Configure signing. With an API key: manual signing with an Apple Distribution
        cert + App Store profile fetched/created via cert+sigh (works headless, no
        registered devices needed — automatic signing fails at archive time because
        Xcode wants a development profile and the team has no devices).
        Without an API key: fall back to automatic signing with the team ID."
  private_lane :configure_signing do |options|
    api_key = options[:api_key]
    team_id = ENV["ASC_TEAM_ID"] || ENV["DEVELOPMENT_TEAM"]

    if api_key && !team_id.to_s.empty?
      get_certificates(
        api_key: api_key,
        team_id: team_id,
        output_path: OUTPUT_DIR
      )
      get_provisioning_profile(
        api_key: api_key,
        app_identifier: APP_IDENTIFIER,
        team_id: team_id,
        output_path: OUTPUT_DIR
      )
      update_code_signing_settings(
        path: XCODEPROJ,
        use_automatic_signing: false,
        team_id: team_id,
        targets: ["UltraEdge"],
        code_sign_identity: "Apple Distribution",
        profile_name: ENV["SIGH_NAME"]
      )
    elsif team_id.to_s.empty?
      UI.important("ASC_TEAM_ID/DEVELOPMENT_TEAM not set — leaving project signing settings as-is.")
    else
      update_code_signing_settings(
        path: XCODEPROJ,
        use_automatic_signing: true,
        team_id: team_id
      )
    end
  end

  desc "Increment build number (TestFlight latest + 1 when API key present)"
  private_lane :bump_build_number do |options|
    api_key = options[:api_key]
    if api_key
      latest = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: APP_IDENTIFIER,
        initial_build_number: 0
      )
      increment_build_number(xcodeproj: XCODEPROJ, build_number: (latest + 1).to_s)
    else
      increment_build_number(xcodeproj: XCODEPROJ)
    end
  end

  desc "Archive the app with gym"
  private_lane :archive do
    team_id = ENV["ASC_TEAM_ID"] || ENV["DEVELOPMENT_TEAM"]
    profile_name = ENV["SIGH_NAME"]

    if profile_name.to_s.empty?
      export_options = { signingStyle: "automatic" }
    else
      export_options = {
        signingStyle: "manual",
        provisioningProfiles: { APP_IDENTIFIER => profile_name }
      }
    end
    export_options[:teamID] = team_id unless team_id.to_s.empty?

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: OUTPUT_DIR,
      output_name: "UltraEdge",
      export_options: export_options,
      xcargs: team_id.to_s.empty? ? nil : "DEVELOPMENT_TEAM=#{team_id}"
    )
  end
end
