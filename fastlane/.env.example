# Fastlane environment variables for UltraEdge iOS builds.
# Copy to fastlane/.env (gitignored) and fill in real values. NEVER commit secrets.

# --- App Store Connect API key (required for `beta` lane) ---
# Create at https://appstoreconnect.apple.com/access/integrations/api
# Role: App Manager (or Admin). Download the .p8 once — Apple won't show it again.

# Key ID (e.g. D383SF739)
ASC_KEY_ID=

# Issuer ID (UUID shown at the top of the Integrations page)
ASC_ISSUER_ID=

# Option A: path to the downloaded .p8 file
ASC_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# Option B: the raw .p8 contents instead of a path (set ASC_KEY_P8_BASE64=true
# if you base64-encoded it, e.g. for CI secrets)
# ASC_KEY_P8=
# ASC_KEY_P8_BASE64=false

# --- Signing ---
# Apple Developer Team ID (10 chars, from https://developer.apple.com/account -> Membership)
ASC_TEAM_ID=

# Optional: App Store Connect team ID, only needed if your Apple ID
# belongs to multiple App Store Connect teams.
# ASC_ITC_TEAM_ID=
